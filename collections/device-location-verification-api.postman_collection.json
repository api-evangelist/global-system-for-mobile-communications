  "info": {
    "_postman_id": "5f5b6a3d-6068-4a93-bfb8-460744a10bff",
    "name": "Global System for Mobile Communications GSMA Camara Project Device Location Verification API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Device Location Verification API checks if a mobile device is in proximity of a given location. The API request contains the location to be checked and an accuracy range in km (between 2km and 200km). The API response indicates whether the location is within the accuracy range of the last known location of the MSISDN.",
      "type": "text/plain"
    }
  }
