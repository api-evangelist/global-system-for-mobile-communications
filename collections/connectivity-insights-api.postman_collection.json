{
  "item": [
    {
      "id": "8cd81996-1619-44ca-a85f-634863119f27",
      "name": "Network Quality",
      "description": {
        "content": "Read the network's level of confidence that it can meet the quality\nthresholds for a given application profile and end user device.\n",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "e85cd459-6af5-4429-8a75-a4a98ab983f1",
          "name": "Global System for Mobile Communications Check the network quality.",
          "request": {
            "name": "Global System for Mobile Communications Check the network quality.",
            "description": {
              "content": "Check the network quality. The response shows the network's current\n level of confidence that it can meet an application profile's quality\n thresholds for a given end user device.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "check-network-quality"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "API root, defined by service provider, e.g.\n`api.example.com` or `api.example.com/somepath`\n",
                  "type": "any",
                  "value": "{{apiRoot}}",
                  "key": "apiRoot"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicationProfileId\": \"<uuid>\",\n  \"device\": {\n    \"phoneNumber\": \"<string>\",\n    \"networkAccessIdentifier\": \"<string>\",\n    \"ipv4Address\": {},\n    \"ipv6Address\": \"<ipv6>\"\n  },\n  \"applicationServer\": {\n    \"ipv4Address\": \"<string>\",\n    \"ipv6Address\": \"<string>\"\n  },\n  \"applicationServerPorts\": {\n    \"ranges\": [\n      {\n        \"from\": \"<integer>\",\n        \"to\": \"<integer>\"\n      }\n    ],\n    \"ports\": [\n      \"<integer>\"\n    ]\n  },\n  \"monitoringTimeStamp\": \"<dateTime>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "47256b4a-9fec-4b36-aedd-880f9838e2cc",
              "name": "OK",
              "originalRequest": {
                "url": {
                  "path": [
                    "check-network-quality"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [],
                  "variable": [
                    {
                      "description": "API root, defined by service provider, e.g.\n`api.example.com` or `api.example.com/somepath`\n",
                      "type": "any",
                      "value": "{{apiRoot}}",
                      "key": "apiRoot"
                    }
                  ]
                },
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"applicationProfileId\": \"<uuid>\",\n  \"device\": {\n    \"phoneNumber\": \"123456789\",\n    \"networkAccessIdentifier\": \"123456789@domain.com\",\n    \"ipv4Address\": {},\n    \"ipv6Address\": \"2001:db8:85a3:8d3:1319:8a2e:370:7344\"\n  },\n  \"applicationServer\": {\n    \"ipv4Address\": \"192.168.0.1/24\",\n    \"ipv6Address\": \"2001:db8:85a3:8d3:1319:8a2e:370:7344\"\n  },\n  \"applicationServerPorts\": {\n    \"ranges\": [\n      {\n        \"from\": \"<integer>\",\n        \"to\": \"<integer>\"\n      }\n    ],\n    \"ports\": [\n      \"<integer>\"\n    ]\n  },\n  \"monitoringTimeStamp\": \"<dateTime>\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "disabled": false,
                  "description": "Correlation id for the different services",
                  "key": "x-correlator",
                  "value": "string"
                },
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"packetDelayBudget\": \"unable to meet the application requirements\",\n  \"targetMinDownstreamRate\": \"meets the application requirements\",\n  \"targetMinUpstreamRate\": \"unable to meet the application requirements\",\n  \"packetlossErrorRate\": \"unable to meet the application requirements\",\n  \"jitter\": \"unable to meet the application requirements\",\n  \"additionalKPIs\": {\n    \"signalStrength\": \"excellent\",\n    \"connectivityType\": \"4G\"\n  }\n}",
