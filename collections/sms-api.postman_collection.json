    "_postman_id": "2dc530eb-001a-47fe-a3b2-c1ecd7d5c7f5",
    "name": "Global System for Mobile Communications GSMA Camara Project SMS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "SMS API provides the customer with the ability to send an SMS to a mobile phone number in use on a mobile phone device. There are 3 different categories of SMS, namely Service SMS, Promotional SMS and Transactional SMS.  The SMS API can also be used to send a binary message to a mobile phone number which is being used on an (IoT) device.\u000b \n\nContact Support:\n Name: API Support\n Email: support@example.com",
      "type": "text/plain"
    }
  }
