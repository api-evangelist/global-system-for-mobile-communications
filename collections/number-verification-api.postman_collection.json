    {
      "id": "268c0ea7-d718-465d-9e7c-5fbbe4a70ad0",
      "name": "Phone Number Verify",
      "description": {
        "content": "API operation to verify a phone number received as input. It can be received either in plain text or hashed format.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "4483c067-e3f4-47a7-ae70-ab309569eebc",
          "name": "Global System for Mobile Communications Verifies if the received hashed/plain text phone number matches the phone number associated with the access token",
          "request": {
            "name": "Global System for Mobile Communications Verifies if the received hashed/plain text phone number matches the phone number associated with the access token",
            "description": {
              "content": "Verifies if the specified phone number (either in plain text or hashed format) matches the one that the user is currently using. Only one of the plain or hashed formats must be provided.\n- The number verification will be done for the user that has authenticated via mobile network\n- It returns true/false depending on if the hashed phone number received as input matches the authenticated user's `device phone number` associated to the access token\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "verify"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "API root, defined by the service provider, e.g. `api.example.com` or `api.example.com/somepath",
                  "type": "any",
                  "value": "{{apiRoot}}",
                  "key": "apiRoot"
                }
              ]
            },
            "header": [
              {
                "disabled": false,
                "description": "Correlation id for the different services",
                "key": "x-correlator",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"<string>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
